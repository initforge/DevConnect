# AI Worker Environment Configuration
# Copy this file to .dev.vars for local development with `wrangler dev`

# Secret key for backend-to-worker authentication
AI_WORKER_SECRET=your-worker-secret-here

# ========== Workers AI Models (set via wrangler.toml or dashboard) ==========
# Default models are defined in wrangler.toml [vars] section
# Override them here if needed for local development
# AI_MODEL_CODE_REVIEW=@cf/meta/llama-3.1-8b-instruct
# AI_MODEL_EXPLAIN=@cf/meta/llama-3.1-8b-instruct
# AI_MODEL_MENTORSHIP=@cf/meta/llama-3.1-8b-instruct
