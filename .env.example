# DevConnect Environment Configuration
# Copy this file to .env and fill in the values

# ========== Backend ==========
PORT=8080
WS_PORT=8081
NODE_ENV=development
DATABASE_URL=postgresql://devconnect:devconnect123@localhost:5432/devconnect
JWT_SECRET=your-secret-key-here

# Rate limiting (Redis-based: 20 requests then 30s cooldown)
# Configured in ai.service.ts, no env override needed

# GitHub OAuth (optional)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ========== AI Cloudflare Workers Proxy ==========
# After deploying the AI Worker (cd ai-worker && ./deploy.sh),
# replace AI_WORKER_URL with the actual workers.dev URL shown by Wrangler.
# Leave empty to use the built-in fallback logic (rule-based AI responses).
AI_WORKER_URL=https://devconnect-ai-worker.your-subdomain.workers.dev
# Must match the secret set via `wrangler secret put AI_WORKER_SECRET`.
# Generate one with: openssl rand -hex 32
AI_WORKER_SECRET=your-worker-secret-here
# Request timeout in milliseconds
AI_TIMEOUT_MS=10000

# AI Models (configured in Workers AI, not typically changed)
# These are read by the backend to pass to the worker if needed
# AI_MODEL_CODE_REVIEW=@cf/meta/llama-3.1-8b-instruct
# AI_MODEL_EXPLAIN=@cf/meta/llama-3.1-8b-instruct
# AI_MODEL_MENTORSHIP=@cf/meta/llama-3.1-8b-instruct

# ========== Piston — Code Execution Engine ==========
# Self-hosted via Docker Compose (see docker-compose.yml piston service)
PISTON_URL=http://localhost:2000
PISTON_TIMEOUT_MS=15000

# ========== Firebase FCM (Push Notifications) ==========
# Get from Firebase Console → Project Settings → Cloud Messaging → Service account
FIREBASE_SERVICE_ACCOUNT_PATH=
FIREBASE_SERVICE_ACCOUNT_JSON=
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----\n"

# ========== Cloudflare API (for AI Worker deployment) ==========
# Get from https://dash.cloudflare.com/profile/api-tokens
# Token needs: Workers Scripts:Edit, Account Settings:Read
CLOUDFLARE_API_TOKEN=your-cloudflare-api-token
CLOUDFLARE_ACCOUNT_ID=your-cloudflare-account-id

# ========== Redis (optional, for caching) ==========
# Used by BullMQ and Redis caching layer
# Docker compose Redis is on profile "cache": docker compose --profile cache up -d
REDIS_URL=redis://localhost:6379

# ========== OpenRouter (AI API) ==========
# Get from https://openrouter.ai/keys
# Used by the AI Worker for code review, explain, and mentorship features
OPENROUTER_API_KEY=your-openrouter-api-key-here
